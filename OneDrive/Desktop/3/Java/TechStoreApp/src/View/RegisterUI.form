              <AuxValues>
                <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JPanel(){&#xa;    {&#xa;        // Quan tr&#x1ecd;ng: Ph&#x1ea3;i &#x111;&#x1ec3; trong su&#x1ed1;t &#x111;&#x1ec3; th&#x1ea5;y &#x111;&#x1b0;&#x1ee3;c bo g&#xf3;c tr&#xea;n n&#x1ec1;n cha&#xa;        setOpaque(false);&#xa;    }&#xa;&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        super.paintComponent(g);&#xa;        java.awt.Graphics2D g2d = (java.awt.Graphics2D) g.create(); // D&#xf9;ng .create() &#x111;&#x1ec3; gi&#x1eef; an to&#xe0;n cho Graphics g&#x1ed1;c&#xa;&#xa;        // --- B&#x1ead;t c&#xe1;c ch&#x1ebf; &#x111;&#x1ed9; l&#xe0;m n&#xe9;t v&#xe0; ch&#x1ed1;ng r&#x103;ng c&#x1b0;a cho &#x111;&#x1b0;&#x1edd;ng cong ---&#xa;        g2d.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xa;        g2d.setRenderingHint(java.awt.RenderingHints.KEY_INTERPOLATION, java.awt.RenderingHints.VALUE_INTERPOLATION_BILINEAR);&#xa;        g2d.setRenderingHint(java.awt.RenderingHints.KEY_RENDERING, java.awt.RenderingHints.VALUE_RENDER_QUALITY);&#xa;&#xa;        int width = getWidth();&#xa;        int height = getHeight();&#xa;        int arc = 30; // &#x110;&#x1ed9; bo g&#xf3;c (ch&#x1ec9;nh s&#x1ed1; n&#xe0;y c&#xe0;ng l&#x1edb;n g&#xf3;c c&#xe0;ng tr&#xf2;n)&#xa;&#xa;        // --- T&#x1ea1;o khu&#xf4;n c&#x1eaf;t bo g&#xf3;c (Clipping) ---&#xa;        // S&#x1eed; d&#x1ee5;ng Shape &#x111;&#x1ec3; c&#x1eaf;t &#x1ea3;nh theo h&#xec;nh ch&#x1eef; nh&#x1ead;t bo g&#xf3;c&#xa;        java.awt.geom.RoundRectangle2D roundRect = new java.awt.geom.RoundRectangle2D.Float(0, 0, width, height, arc, arc);&#xa;        g2d.setClip(roundRect);&#xa;&#xa;        java.net.URL imgURL = getClass().getResource(&quot;/Resource/backgroundLogin1.png&quot;);&#xa;        if (imgURL != null) {&#xa;            javax.swing.ImageIcon icon = new javax.swing.ImageIcon(imgURL);&#xa;            // V&#x1ebd; &#x1ea3;nh v&#xe0;o trong khu&#xf4;n &#x111;&#xe3; c&#x1eaf;t&#xa;            g2d.drawImage(icon.getImage(), 0, 0, width, height, this);&#xa;        } else {&#xa;            g2d.setColor(new java.awt.Color(10, 50, 120));&#xa;            g2d.fillRoundRect(0, 0, width, height, arc, arc);&#xa;        }&#xa;&#xa;        g2d.dispose(); // Gi&#x1ea3;i ph&#xf3;ng t&#xe0;i nguy&#xea;n &#x111;&#x1ed3; h&#x1ecd;a&#xa;    }&#xa;}"/>
              </AuxValues>

